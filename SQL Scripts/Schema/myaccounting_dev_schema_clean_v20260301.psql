--
-- Name: account rls_account_owner; Type: POLICY; Schema: public; Owner: -
--

CREATE POLICY rls_account_owner ON public.account USING ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id())))) WITH CHECK ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id()))));


--
-- Name: ledger rls_ledger_owner; Type: POLICY; Schema: public; Owner: -
--

CREATE POLICY rls_ledger_owner ON public.ledger USING ((owner_id = public.mab_current_owner_id())) WITH CHECK ((owner_id = public.mab_current_owner_id()));


--
-- Name: payee rls_payee_owner; Type: POLICY; Schema: public; Owner: -
--

CREATE POLICY rls_payee_owner ON public.payee USING ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id())))) WITH CHECK ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id()))));


--
-- Name: scheduled_transaction rls_scheduled_transaction_owner; Type: POLICY; Schema: public; Owner: -
--

CREATE POLICY rls_scheduled_transaction_owner ON public.scheduled_transaction USING ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id())))) WITH CHECK ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id()))));


--
-- Name: split rls_split_owner; Type: POLICY; Schema: public; Owner: -
--

CREATE POLICY rls_split_owner ON public.split USING ((account_id IN ( SELECT a.id
   FROM (public.account a
     JOIN public.ledger l ON ((l.id = a.ledger_id)))
  WHERE (l.owner_id = public.mab_current_owner_id())))) WITH CHECK ((account_id IN ( SELECT a.id
   FROM (public.account a
     JOIN public.ledger l ON ((l.id = a.ledger_id)))
  WHERE (l.owner_id = public.mab_current_owner_id()))));


--
-- Name: transaction rls_transaction_owner; Type: POLICY; Schema: public; Owner: -
--

CREATE POLICY rls_transaction_owner ON public.transaction USING ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id())))) WITH CHECK ((ledger_id IN ( SELECT ledger.id
   FROM public.ledger
  WHERE (ledger.owner_id = public.mab_current_owner_id()))));


