    occurred_at timestamp with time zone DEFAULT now() NOT NULL,
    table_name text NOT NULL,
    operation text NOT NULL,
    row_id uuid,
    owner_id uuid,
    old_data jsonb,
    new_data jsonb,
    app_user text DEFAULT CURRENT_USER NOT NULL,
    CONSTRAINT chk_audit_operation CHECK ((operation = ANY (ARRAY['INSERT'::text, 'UPDATE'::text, 'DELETE'::text])))
);


--
-- Name: TABLE audit_log; Type: COMMENT; Schema: public; Owner: -
--

COMMENT ON TABLE public.audit_log IS 'Append-only compliance audit trail. Populated by mab_audit_trigger(). Never UPDATE or DELETE rows here.';


